{
  "mcpServers": {
    "wechat-official-account": {
      "command": "node",
      "args": [
        "wechat-mcp",
        "mcp",
        "-a",
        "YOUR_WECHAT_APP_ID",
        "-s",
        "YOUR_WECHAT_APP_SECRET"
      ],
      "disabled": false
    },
    "xiaohongshu-mcp": {
      "type": "http",
      "url": "http://localhost:18060/mcp",
      "description": "小红书 MCP（需先启动本地服务）",
      "disabled": false
    }
  }
}
